# ── Auth ──────────────────────────────────────────
AUTH_SECRET=           # Generate with: openssl rand -base64 32
AUTH_TRUST_HOST=true

# GitHub OAuth (create at https://github.com/settings/developers)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Resend for magic link emails (optional, get key at https://resend.com)
# AUTH_RESEND_KEY=

# ── Database ──────────────────────────────────────
DATABASE_URL=          # Neon Postgres connection string

# ── Storage ───────────────────────────────────────
# BLOB_READ_WRITE_TOKEN=  # Vercel Blob (for media uploads)

# ── AI (optional — for Explain feature) ──────────
# Users bring their own API key in account settings (BYOK)
